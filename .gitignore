# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
venv/
env/
.venv/
ENV/

# ---- Logs / temp ----
*.log
*.tmp
*.bak
*.swp

# ---- Python / project artifacts ----
*.pyproj

# ---- SQLite / database ----
*.sqlite
*.sqlite3
*.db
*.db-journal

# Keep only if you truly never want any DB in git
# data/dota.db

# ---- Environment / secrets ----
.env
.env.*
backend/.env
config/*.env
config/.env

# ---- Node / JavaScript ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
.cache/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.code-workspace

# ---- Deployment artifacts ----
deploy/
releases/
tmp/

# ---- Generated project outputs ----
logs/
data/exports/
data/derived/

# ---- Optional raw working files ----
# Ignore raw data dumps if they are large or temporary
# data/raw/

# ---- Archive helpers ----
# If archive is just for reference and you want it committed, leave it alone.
# If not, uncomment:
# archive/